.oG5Srb .Vwe4Vb, .zZhnYe .Vwe4Vb { background-image: radial-gradient(circle farthest-side, rgba(0, 0, 0, 0.12), rgba(0, 0, 0, 0.12) 80%, transparent 100%); }

.HQ8yf .Vwe4Vb { background-image: radial-gradient(circle farthest-side, rgba(66, 133, 244, 0.25), rgba(66, 133, 244, 0.25) 80%, transparent 100%); }

