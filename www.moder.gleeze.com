body#layout .hamburger-menu, body#layout .search { display: none; }

.centered-top-container .svg-icon-24, body.collapsed-header .centered-top-placeholder .svg-icon-24 { fill: rgb(255, 255, 255); }

.sidebar-container .svg-icon-24 { fill: rgb(112, 112, 112); }

