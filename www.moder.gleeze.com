.splash { background: rgb(204, 204, 204); border-radius: 100%; display: block; opacity: 0.6; position: absolute; transform: scale(0); }

.splash.animate { animation: 0.4s linear 0s 1 normal none running ripple-effect; }

@-webkit-keyframes ripple-effect { 
  100% { opacity: 0; transform: scale(2.5); }
}

@keyframes ripple-effect { 
  100% { opacity: 0; transform: scale(2.5); }
}

.search { display: flex; line-height: 24px; width: 24px; }

.search.focused { width: 100%; }

.search.focused .section { width: 100%; }

.search form { z-index: 101; }

.search h3 { display: none; }

.search form { display: flex; -webkit-box-flex: 1; flex: 1 0 0px; border-bottom: 1px solid transparent; padding-bottom: 8px; }

.search form > * { display: none; }

.search.focused form > * { display: block; }

.search .search-input label { display: none; }

.centered-top-placeholder.cloned .search form { z-index: 30; }

.search.focused form { border-color: rgb(255, 255, 255); position: relative; width: auto; }

.collapsed-header .centered-top-container .search.focused form { border-bottom-color: transparent; }

.search-expand { -webkit-box-flex: 0; flex: 0 0 auto; }

.search-expand-text { display: none; }

.search-close { display: inline; vertical-align: middle; }

.search-input { -webkit-box-flex: 1; flex: 1 0 1px; }

.search-input input { background: 0px 0px; border: 0px; box-sizing: border-box; color: rgb(255, 255, 255); display: inline-block; outline: 0px; width: calc(100% - 48px); }

.search-input input.no-cursor { color: transparent; text-shadow: rgb(255, 255, 255) 0px 0px 0px; }

.collapsed-header .centered-top-container .search-action, .collapsed-header .centered-top-container .search-input input { color: rgb(33, 33, 33); }

.collapsed-header .centered-top-container .search-input input.no-cursor { color: transparent; text-shadow: rgb(33, 33, 33) 0px 0px 0px; }

.collapsed-header .centered-top-container .search-input input.no-cursor:focus, .search-input input.no-cursor:focus { outline: 0px; }

.search-focused > * { visibility: hidden; }

.search-focused .search, .search-focused .search-icon { visibility: visible; }

.search.focused .search-action { display: block; }

.search.focused .search-action:disabled { opacity: 0.3; }

.widget.Sharing .sharing-button { display: none; }

.widget.Sharing .sharing-buttons li { padding: 0px; }

.widget.Sharing .sharing-buttons li span { display: none; }

.post-share-buttons { position: relative; }

.centered-bottom .share-buttons .svg-icon-24, .share-buttons .svg-icon-24 { fill: rgb(33, 33, 33); }

.sharing-open.touch-icon-button:active .touch-icon, .sharing-open.touch-icon-button:focus .touch-icon { background-color: transparent; }

.share-buttons { background-color: rgb(255, 255, 255); border-radius: 2px; box-shadow: rgba(0, 0, 0, 0.14) 0px 2px 2px 0px, rgba(0, 0, 0, 0.2) 0px 3px 1px -2px, rgba(0, 0, 0, 0.12) 0px 1px 5px 0px; color: rgb(33, 33, 33); list-style: none; margin: 0px; padding: 8px 0px; position: absolute; top: -11px; min-width: 200px; z-index: 101; }

.share-buttons.hidden { display: none; }

.sharing-button { background: 0px 0px; border: 0px; margin: 0px; outline: 0px; padding: 0px; cursor: pointer; }

.share-buttons li { margin: 0px; height: 48px; }

.share-buttons li:last-child { margin-bottom: 0px; }

.share-buttons li .sharing-platform-button { box-sizing: border-box; cursor: pointer; display: block; height: 100%; margin-bottom: 0px; padding: 0px 16px; position: relative; width: 100%; }

.share-buttons li .sharing-platform-button:focus, .share-buttons li .sharing-platform-button:hover { background-color: rgba(128, 128, 128, 0.1); outline: 0px; }

.share-buttons li svg[class*=" sharing-"], .share-buttons li svg[class^="sharing-"] { position: absolute; top: 10px; }

.share-buttons li span.sharing-platform-button { position: relative; top: 0px; }

.share-buttons li .platform-sharing-text { display: block; font-size: 16px; line-height: 48px; white-space: nowrap; }

.share-buttons li .platform-sharing-text { margin-right: 56px; }

.sidebar-container { background-color: rgb(255, 255, 255); max-width: 284px; overflow-y: auto; transition-property: transform, -webkit-transform; transition-duration: 0.3s; transition-timing-function: cubic-bezier(0, 0, 0.2, 1); width: 284px; z-index: 101; }

.sidebar-container .navigation { line-height: 0; padding: 16px; }

.sidebar-container .sidebar-back { cursor: pointer; }

.sidebar-container .widget { background: 0px 0px; margin: 0px 16px; padding: 16px 0px; }

.sidebar-container .widget .title { color: rgb(33, 33, 33); margin: 0px; }

.sidebar-container .widget ul { list-style: none; margin: 0px; padding: 0px; }

.sidebar-container .widget ul ul { margin-right: 1em; }

.sidebar-container .widget li { font-size: 16px; line-height: normal; }

.sidebar-container .widget + .widget { border-top: 1px dashed rgb(204, 204, 204); }

.BlogArchive li { margin: 16px 0px; }

.BlogArchive li:last-child { margin-bottom: 0px; }

.Label li a { display: inline-block; }

.BlogArchive .post-count, .Label .label-count { float: left; margin-right: 0.25em; }

.BlogArchive .post-count::before, .Label .label-count::before { content: "("; }

.BlogArchive .post-count::after, .Label .label-count::after { content: ")"; }

.widget.Translate .skiptranslate > div { display: block !important; }

.widget.Profile .profile-link { display: flex; }

.widget.Profile .team-member .default-avatar-wrapper, .widget.Profile .team-member .profile-img { -webkit-box-flex: 0; flex: 0 0 auto; margin-left: 1em; }

.widget.Profile .individual .profile-link { -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; }

.widget.Profile .team .profile-link .profile-name { align-self: center; display: block; -webkit-box-flex: 1; flex: 1 1 auto; }

.dim-overlay { background-color: rgba(0, 0, 0, 0.54); z-index: 100; }

body.sidebar-visible { overflow-y: hidden; }

@media screen and (max-width: 1439px) {
  .sidebar-container { inset: 0px auto 0px 0px; position: fixed; }
  .sidebar-container.sidebar-invisible { transition-timing-function: cubic-bezier(0.4, 0, 0.6, 1); transform: translateX(-284px); }
}

@media screen and (min-width: 1440px) {
  .sidebar-container { position: absolute; top: 0px; left: 0px; right: auto; }
  .sidebar-container .navigation { display: none; }
}

.dialog { box-shadow: rgba(0, 0, 0, 0.14) 0px 2px 2px 0px, rgba(0, 0, 0, 0.2) 0px 3px 1px -2px, rgba(0, 0, 0, 0.12) 0px 1px 5px 0px; background: rgb(255, 255, 255); box-sizing: border-box; color: rgb(33, 150, 243); padding: 30px; position: fixed; text-align: center; width: calc(100% - 24px); z-index: 101; }

.dialog input[type="email"], .dialog input[type="text"] { background-color: transparent; border-width: 0px 0px 1px; border-top-style: initial; border-right-style: initial; border-left-style: initial; border-top-color: initial; border-right-color: initial; border-left-color: initial; border-image: initial; border-bottom-style: solid; border-bottom-color: rgba(33, 150, 243, 0.12); color: rgb(33, 150, 243); display: block; font-family: Roboto, sans-serif; font-size: 16px; line-height: 24px; margin: auto; padding-bottom: 7px; outline: 0px; text-align: center; width: 100%; }

.dialog input[type="email"]::-webkit-input-placeholder, .dialog input[type="text"]::-webkit-input-placeholder { color: rgb(33, 150, 243); }

.dialog input[type="email"]::placeholder, .dialog input[type="text"]::placeholder { color: rgb(33, 150, 243); }

.dialog input[type="email"]:focus, .dialog input[type="text"]:focus { border-bottom: 2px solid rgb(33, 150, 243); padding-bottom: 6px; }

.dialog input.no-cursor { color: transparent; text-shadow: rgb(33, 150, 243) 0px 0px 0px; }

.dialog input.no-cursor:focus { outline: 0px; }

.dialog input.no-cursor:focus { outline: 0px; }

.dialog input[type="submit"] { font-family: Roboto, sans-serif; }

.dialog .goog-buttonset-default { color: rgb(33, 150, 243); }

.subscribe-popup { max-width: 364px; }

.subscribe-popup h3 { color: rgb(33, 33, 33); font-size: 1.8em; margin-top: 0px; }

.subscribe-popup .FollowByEmail h3 { display: none; }

.subscribe-popup .FollowByEmail .follow-by-email-submit { color: rgb(33, 150, 243); display: inline-block; margin: 24px auto 0px; width: auto; white-space: normal; }

.subscribe-popup .FollowByEmail .follow-by-email-submit:disabled { cursor: default; opacity: 0.3; }

