.blogger-logo, .svg-icon-24.blogger-logo { fill: rgb(255, 152, 0); opacity: 1; }

.loading-spinner-large { animation: 1.568s linear 0s infinite normal none running mspin-rotate; height: 48px; overflow: hidden; position: absolute; width: 48px; z-index: 200; }

.loading-spinner-large > div { animation: 5332ms steps(4) 0s infinite normal none running mspin-revrot; }

.loading-spinner-large > div > div { animation: 1333ms steps(81) 0s infinite normal none running mspin-singlecolor-large-film; background-size: 100%; height: 48px; width: 3888px; }

.mspin-black-large > div > div, .mspin-grey_54-large > div > div { background-image: url("https://www.blogblog.com/indie/mspin_black_large.svg"); }

.mspin-white-large > div > div { background-image: url("https://www.blogblog.com/indie/mspin_white_large.svg"); }

.mspin-grey_54-large { opacity: 0.54; }

@-webkit-keyframes mspin-singlecolor-large-film { 
  0% { transform: translateX(0px); }
  100% { transform: translateX(-3888px); }
}

@keyframes mspin-singlecolor-large-film { 
  0% { transform: translateX(0px); }
  100% { transform: translateX(-3888px); }
}

@-webkit-keyframes mspin-rotate { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes mspin-rotate { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@-webkit-keyframes mspin-revrot { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(-360deg); }
}

@keyframes mspin-revrot { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(-360deg); }
}

.skip-navigation { background-color: rgb(255, 255, 255); box-sizing: border-box; color: rgb(0, 0, 0); display: block; height: 0px; left: 0px; line-height: 50px; overflow: hidden; padding-top: 0px; position: fixed; text-align: center; top: 0px; transition: box-shadow 0.3s, height 0.3s, padding-top 0.3s; width: 100%; z-index: 900; }

