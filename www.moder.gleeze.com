.tabs { list-style: none; }

.tabs li { display: inline-block; }

.tabs li a { cursor: pointer; display: inline-block; font-weight: 700; text-transform: uppercase; padding: 12px 8px; }

.tabs .selected { border-bottom: 4px solid rgb(255, 255, 255); }

.tabs .selected a { color: rgb(255, 255, 255); }

body#layout .bg-photo, body#layout .bg-photo-overlay { display: none; }

body#layout .page_body { padding: 0px; position: relative; top: 0px; }

body#layout .page { display: inline-block; left: inherit; position: relative; vertical-align: top; width: 540px; }

