@charset "utf-8";

html { line-height: 1.15; text-size-adjust: 100%; }

body { margin: 0px; }

h1 { font-size: 2em; margin: 0.67em 0px; }

hr { box-sizing: content-box; height: 0px; overflow: visible; }

pre { font-family: monospace, monospace; font-size: 1em; }

a { background-color: transparent; }

abbr[title] { border-bottom: none; text-decoration: underline dotted; }

b, strong { font-weight: bolder; }

code, kbd, samp { font-family: monospace, monospace; font-size: 1em; }

small { font-size: 80%; }

sub, sup { font-size: 75%; line-height: 0; position: relative; vertical-align: baseline; }

sub { bottom: -0.25em; }

sup { top: -0.5em; }

img { border-style: none; }

button, input, optgroup, select, textarea { font-family: inherit; font-size: 100%; line-height: 1.15; margin: 0px; }

button, input { overflow: visible; }

button, select { text-transform: none; }

button, [type="button"], [type="reset"], [type="submit"] { appearance: button; }

fieldset { padding: 0.35em 0.75em 0.625em; }

legend { box-sizing: border-box; color: inherit; display: table; max-width: 100%; padding: 0px; white-space: normal; }

progress { vertical-align: baseline; }

textarea { overflow: auto; }

[type="checkbox"], [type="radio"] { box-sizing: border-box; padding: 0px; }

[type="number"]::-webkit-inner-spin-button, [type="number"]::-webkit-outer-spin-button { height: auto; }

[type="search"] { appearance: textfield; }

[type="search"]::-webkit-search-decoration { appearance: none; }

::-webkit-file-upload-button { appearance: button; font: inherit; }

details { display: block; }

summary { display: list-item; }

template { display: none; }

[hidden] { display: none; }

body { word-break: break-word; overflow-wrap: break-word; }

.hidden { display: none; }

.invisible { visibility: hidden; }

.container::after, .float-container::after { clear: both; content: ""; display: table; }

.clearboth { clear: both; }

#commentsHolder .dialog input[type="button"], #editButton a, #postCommentSubmit, #signoutLink .signoutButton { background: transparent; border: 0px; box-shadow: none; color: rgb(33, 150, 243); cursor: pointer; font-size: 14px; font-weight: 700; outline: none; text-decoration: none; text-transform: uppercase; width: auto; }

.dim-overlay { background-color: rgba(0, 0, 0, 0.54); height: 100vh; left: 0px; position: fixed; top: 0px; width: 100%; }

#sharing-dim-overlay { background-color: transparent; }

.blogger-logo, .svg-icon-24.blogger-logo { fill: rgb(255, 152, 0); opacity: 1; }

html { background: rgb(255, 255, 255); }

html, html body { height: 100%; margin: 0px; padding: 0px; }

html body { background-color: transparent; margin: 0px; }

a, body, div, input, option, p, select, span, td, textarea { font: 15px Roboto, sans-serif; }

#commentsHolder { background-color: transparent; border-top: 1px dashed rgb(204, 204, 204); border-bottom: 1px dashed rgb(204, 204, 204); height: 252px; padding: 0px; position: relative; }

#commentsHolder .dialog { background-color: rgb(255, 255, 255); box-sizing: border-box; color: rgb(33, 150, 243); display: none; right: 50px; margin-top: 4px; max-width: calc(100% - 56px); padding: 10px; position: absolute; top: 10px; width: 378px; z-index: 1; }

#commentsHolder .dialog .shown-openid-url { color: rgb(33, 150, 243); margin-top: 5px; }

#commentsHolder .dialog .top h3 { color: rgb(33, 33, 33); margin: 0px 0px 10px; }

#commentsHolder .dialog .dialogField { background-color: rgb(255, 255, 255); border-width: 0px 0px 1px; border-top-style: initial; border-right-style: initial; border-left-style: initial; border-top-color: initial; border-right-color: initial; border-left-color: initial; border-image: initial; border-bottom-style: solid; border-bottom-color: rgb(33, 150, 243); color: rgb(33, 33, 33); margin-top: 4px; outline: none; width: 100%; }

#commentsHolder .dialog input[type="button"] { color: rgb(33, 150, 243); padding: 0px; }

#commentsHolder .dialog .group { margin-bottom: 10px; }

#commentsHolder .continue_btn { float: left; }

.commentBodyContainer { box-sizing: border-box; margin-top: 75px; padding-right: 64px; position: absolute; top: 0px; width: 100%; }

#commentBodyField { background-color: transparent; border: 0px; box-sizing: border-box; color: rgb(33, 150, 243); font: 16px Roboto, sans-serif; height: 142px; outline: none; padding-top: 0px; resize: none; width: inherit; }

#commentSelectorLabel { color: rgb(33, 150, 243); font-weight: 700; margin-left: 10px; }

#identityMenu { background: none; border: 0px; color: rgb(33, 150, 243); height: auto; margin: 0px; max-width: 160px; outline: none; padding: 0px; width: auto; }

#identityMenu option { background-color: rgb(255, 255, 255); }

#commentBodyField:focus { border: 0px; box-shadow: none; }

#allHolder { background-color: transparent; border: 0px; }

#postCommentButtonHolder { background-color: transparent; padding: 10px 0px 4px; }

#postCommentButtonHolder::after { clear: both; content: ""; display: table; }

#subscribeButtonHolder { color: rgb(33, 150, 243); cursor: pointer; float: right; }

#subscribeButtonHolder .notifyMeCheckboxEmpty, #subscribeButtonHolder .notifyMeCheckboxFull { display: inline-block; fill: rgb(33, 150, 243); }

#subscribeButtonHolder .notifyMeCheckboxFull { display: none; }

#subscribeButtonHolder.checked .notifyMeCheckboxFull { display: inline-block; }

#subscribeButtonHolder.checked .notifyMeCheckboxEmpty { display: none; }

#subscribeButtonHolder .checkboxLabel { float: left; line-height: 24px; padding-right: 3px; }

#postCommentSubmit { color: rgb(33, 150, 243); float: left; margin: 0px 0px 0px 10px; padding: 0px; }

#postCommentSubmit:disabled { cursor: auto; opacity: 0.26; }

#postCommentSubmit:hover { background: transparent; border: 0px; box-shadow: none; color: rgb(33, 150, 243); cursor: pointer; }

#postCommentPreview { display: none; }

#allHolder.previewMode #previewHolder.with-captcha { display: block; }

#allHolder.previewMode #previewHolder img.close { float: none; position: absolute; right: 10px; top: 10px; }

#allHolder.previewMode #previewHolder h3 { display: none; }

#allHolder.previewMode #previewHolder .captcha-container { margin-top: 32px; }

#allHolder.previewMode #previewHolder #comments-block { display: none; }

#allHolder.previewMode #previewHolder .g-recaptcha { margin-top: 10px; }

#identityControlsHolder { height: 40px; margin-top: 25px; padding: 0px; position: absolute; top: 0px; width: 100%; }

#identityControlsHolder .avatar-image-container img { border-radius: 100px; }

#identityControlsHolder .loggedInAvatar { display: block; margin: 0px; width: 38px; }

#identityControlsHolder .identitySelectorContainer { margin-right: 64px; margin-left: 5px; position: absolute; top: 0px; width: calc(100% - 69px); }

#identityControlsHolder .identitySelectorContainer > span { display: inline-block; }

#identityControlsHolder .identitySelectorContainer .dropdown { background-color: transparent; border: 0px; box-shadow: none; display: inline-block; height: inherit; line-height: 30px; outline: none medium; padding-bottom: 3px; }

#identityControlsHolder #id-error { position: absolute; top: 206px; }

#identityControlsHolder .genericAvatar { background-image: url("https://resources.blogblog.com/img/anon36.png"); border-radius: 100px; display: block; height: 36px; width: 36px; }

#signoutLink { cursor: pointer; height: auto; left: 0px; line-height: normal; margin-right: 20px; position: absolute; top: 0px; }

#signoutLink .signoutButton { color: rgb(33, 150, 243); padding: 0px; }

#allHolder.compact #commentsHolder { height: 88px; }

#allHolder.compact .commentBodyContainer { height: 100%; margin-top: 0px; }

#allHolder.compact #commentBodyField { border: 0px; box-sizing: border-box; height: 100%; outline: none; padding-top: 34px; }

#allHolder.compact #identityControlsHolder { width: auto; }

#allHolder.compact #commentSelectorLabel, #allHolder.compact #editButton, #allHolder.compact #identityControlsHolder .dropdown, #allHolder.compact #postCommentButtonHolder, #allHolder.compact #signoutLink { display: none !important; }

#openIdUriDisplayUsername { color: rgb(33, 150, 243); }

#editButton { margin-left: 0px; }

#editButton a { color: rgb(33, 150, 243); }

#identityControlsHolder #settingsButton, #main-error-holder, #main-status-holder { display: none; }

#anonymousWarning, #main-status-holder { color: rgb(33, 150, 243); }

#main-error-holder { color: red; font-weight: 700; }

#main-error-holder .status-msg.error, #main-status-holder .status-msg.status { margin: 0px auto; }

@media (max-width: 350px) {
  span#signoutLink { margin-bottom: 0px; }
}

@media (max-width: 400px) {
  div#commentsHolder { padding: 0px; }
  .expanded .commentBodyContainer { margin-top: 100px; padding: 0px; }
  #allHolder.compact .commentBodyContainer { padding-right: 64px; }
  #commentSelectorLabel { display: block; width: 160px; }
  #identitySelectorContainer .dropdown { width: 160px; }
  #editButton { display: inline; }
}

img.close { cursor: pointer; float: left; margin: 0px; position: relative; }

#openIdUsernameLabel { font-weight: 700; }

.svg-icon-24, .svg-icon-24-button { cursor: pointer; height: 24px; min-width: 24px; width: 24px; }

.touch-icon { margin: -12px; padding: 12px; }

.touch-icon:active, .touch-icon:focus { background-color: rgba(153, 153, 153, 0.4); border-radius: 50%; }

svg:not(:root).touch-icon { overflow: visible; }

html[dir="rtl"] .rtl-reversible-icon { transform: scaleX(-1); }

.svg-icon-24-button, .touch-icon-button { background: transparent; border: 0px; margin: 0px; outline: none; padding: 0px; }

.touch-icon-button .touch-icon:active, .touch-icon-button .touch-icon:focus { background-color: transparent; }

.touch-icon-button:active .touch-icon, .touch-icon-button:focus .touch-icon { background-color: rgba(153, 153, 153, 0.4); border-radius: 50%; }

.Profile .default-avatar-wrapper .avatar-icon { border: 1px solid rgb(33, 150, 243); border-radius: 50%; box-sizing: border-box; fill: rgb(33, 150, 243); margin: 0px; }

.Profile .individual .default-avatar-wrapper .avatar-icon { padding: 25px; }

.Profile .individual .avatar-icon, .Profile .individual .profile-img { height: 120px; width: 120px; }

.Profile .team .default-avatar-wrapper .avatar-icon { padding: 8px; }

.Profile .team .avatar-icon, .Profile .team .default-avatar-wrapper, .Profile .team .profile-img { height: 40px; width: 40px; }

#allHolder .svg-icon-24 { fill: rgb(112, 112, 112); }
