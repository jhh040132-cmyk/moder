.centered-bottom .share-buttons .svg-icon-24, .share-buttons .svg-icon-24 { fill: rgb(33, 33, 33); }

body { background-color: rgb(238, 238, 238); color: rgb(33, 150, 243); font: 15px Roboto, sans-serif; margin: 0px; min-height: 100vh; }

img { max-width: 100%; }

h3 { color: rgb(33, 150, 243); font-size: 16px; }

a { text-decoration: none; color: rgb(33, 150, 243); }

a:visited { color: rgb(33, 150, 243); }

a:hover { color: rgb(33, 150, 243); }

blockquote { color: rgb(68, 68, 68); font: italic 300 x-large Roboto, sans-serif; text-align: center; }

.pill-button { font-size: 12px; }

.bg-photo-container { height: 480px; overflow: hidden; position: absolute; width: 100%; z-index: 1; }

.bg-photo { background: url("https://themes.googleusercontent.com/image?id=L1lcAxxz0CLgsDzixEprHJ2F38TyEjCyE3RSAjynQDks0lT1BDc1OxXKaTEdLc89HPvdB11X9FDw") center top / cover no-repeat scroll rgb(238, 238, 238); filter: blur(0px); height: calc(100% + 0px); left: 0px; position: absolute; top: 0px; width: calc(100% + 0px); }

.bg-photo-overlay { background:  0% 0% / cover rgba(0, 0, 0, 0.26); height: 480px; position: absolute; width: 100%; z-index: 2; }

.hamburger-menu { float: left; margin-top: 0px; }

.sticky .hamburger-menu { float: none; position: absolute; }

.search { border-bottom: 1px solid rgba(255, 255, 255, 0); float: right; position: relative; transition-property: width; transition-duration: 0.5s; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); z-index: 101; }

.search .dim-overlay { background-color: transparent; }

.search form { height: 36px; transition-property: border-color; transition-delay: 0.5s; transition-duration: 0.2s; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); }

.search.focused { width: calc(100% - 48px); }

.search.focused form { display: flex; -webkit-box-flex: 1; flex: 1 0 1px; border-color: rgb(255, 255, 255); margin-right: -24px; padding-right: 36px; position: relative; width: auto; }

.item-view .search, .sticky .search { left: 0px; float: none; margin-left: 0px; position: absolute; }

.item-view .search.focused, .sticky .search.focused { width: calc(100% - 50px); }

.item-view .search.focused form, .sticky .search.focused form { border-bottom-color: rgb(33, 150, 243); }

.centered-top-placeholder.cloned .search form { z-index: 30; }

.search_button { -webkit-box-flex: 0; flex: 0 0 24px; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; }

.search_button svg { margin-top: 0px; }

.search-input { height: 48px; }

.search-input input { display: block; color: rgb(255, 255, 255); font: 16px / 48px Roboto, sans-serif; height: 48px; padding: 0px; width: 100%; }

.search-input input::-webkit-input-placeholder { color: rgb(255, 255, 255); opacity: 0.3; }

.search-input input::placeholder { color: rgb(255, 255, 255); opacity: 0.3; }

.search-action { background: 0px 0px; border: 0px; color: rgb(255, 255, 255); cursor: pointer; display: none; height: 48px; margin-top: 0px; }

.sticky .search-action { color: rgb(33, 150, 243); }

.search.focused .search-action { display: block; }

.search.focused .search-action:disabled { opacity: 0.3; }

.page_body { position: relative; z-index: 20; }

.page_body .widget { margin-bottom: 16px; }

.page_body .centered { box-sizing: border-box; display: flex; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; margin: 0px auto; max-width: 922px; min-height: 100vh; padding: 24px 0px; }

.page_body .centered > * { -webkit-box-flex: 0; flex: 0 0 auto; }

.page_body .centered > #footer { margin-top: auto; }

.blog-name { margin: 24px 0px 16px; }

.item-view .blog-name, .sticky .blog-name { box-sizing: border-box; margin-left: 36px; min-height: 48px; opacity: 1; padding-top: 12px; }

.blog-name .subscribe-section-container { margin-bottom: 32px; text-align: center; transition-property: opacity; transition-duration: 0.5s; }

.item-view .blog-name .subscribe-section-container, .sticky .blog-name .subscribe-section-container { margin: 0px 0px 8px; }

.blog-name .PageList { margin-top: 16px; padding-top: 8px; text-align: center; }

.blog-name .PageList .overflowable-contents { width: 100%; }

.blog-name .PageList h3.title { color: rgb(255, 255, 255); margin: 8px auto; text-align: center; width: 100%; }

.centered-top-container .blog-name { transition-property: opacity; transition-duration: 0.5s; }

.item-view .return_link { margin-bottom: 12px; margin-top: 12px; position: absolute; }

.item-view .blog-name { display: flex; flex-wrap: wrap; margin: 0px 48px 27px; }

.item-view .subscribe-section-container { -webkit-box-flex: 0; flex: 0 0 auto; }

.item-view #header, .item-view .Header { margin-bottom: 5px; margin-right: 15px; }

.item-view .sticky .Header { margin-bottom: 0px; }

.item-view .Header p { margin: 10px 0px 0px; text-align: left; }

.item-view .post-share-buttons-bottom { margin-left: 16px; }

.sticky { background: rgb(255, 255, 255); box-shadow: rgba(0, 0, 0, 0.7) 0px 0px 20px 0px; box-sizing: border-box; margin-left: 0px; }

.sticky #header { margin-bottom: 8px; margin-left: 8px; }

.sticky .centered-top { margin: 4px auto; max-width: 890px; min-height: 48px; }

.sticky .blog-name { display: flex; margin: 0px 48px; }

.sticky .blog-name #header { -webkit-box-flex: 0; flex: 0 1 auto; -webkit-box-ordinal-group: 2; order: 1; overflow: hidden; }

.sticky .blog-name .subscribe-section-container { -webkit-box-flex: 0; flex: 0 0 auto; -webkit-box-ordinal-group: 3; order: 2; }

.sticky .Header h1 { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-left: -10px; margin-bottom: -10px; padding-left: 10px; padding-bottom: 10px; }

.sticky .Header p { display: none; }

.sticky .PageList { display: none; }

.search-focused > * { visibility: visible; }

.search-focused .hamburger-menu { visibility: visible; }

.item-view .search-focused .blog-name, .sticky .search-focused .blog-name { opacity: 0; }

.centered-bottom, .centered-top-container, .centered-top-placeholder { padding: 0px 16px; }

.centered-top { position: relative; }

.item-view .centered-top.search-focused .subscribe-section-container, .sticky .centered-top.search-focused .subscribe-section-container { opacity: 0; }

.page_body.has-vertical-ads .centered .centered-bottom { display: inline-block; width: calc(100% - 176px); }

.Header h1 { color: rgb(255, 255, 255); font: bold 45px Roboto, sans-serif; margin: 0px 0px 13px; text-align: center; width: 100%; }

.Header h1 a, .Header h1 a:hover, .Header h1 a:visited { color: rgb(255, 255, 255); }

.item-view .Header h1, .sticky .Header h1 { font-size: 24px; line-height: 24px; margin: 0px; text-align: left; }

.sticky .Header h1 { color: rgb(33, 150, 243); }

.sticky .Header h1 a, .sticky .Header h1 a:hover, .sticky .Header h1 a:visited { color: rgb(33, 150, 243); }

.Header p { color: rgb(255, 255, 255); margin: 0px 0px 13px; opacity: 0.8; text-align: center; }

.widget .title { line-height: 28px; }

.BlogArchive li { font-size: 16px; }

.BlogArchive .post-count { color: rgb(33, 150, 243); }

#page_body .FeaturedPost, .Blog .blog-posts .post-outer-container { background: rgb(255, 255, 255); min-height: 40px; padding: 30px 40px; width: auto; }

.Blog .blog-posts .post-outer-container:last-child { margin-bottom: 0px; }

.Blog .blog-posts .post-outer-container .post-outer { border: 0px; position: relative; padding-bottom: 0.25em; }

.post-outer-container { margin-bottom: 16px; }

.post:first-child { margin-top: 0px; }

.post .thumb { float: left; height: 20%; width: 20%; }

.post-share-buttons-bottom, .post-share-buttons-top { float: left; }

.post-share-buttons-bottom { margin-left: 24px; }

.post-footer, .post-header { clear: right; color: rgba(0, 0, 0, 0.54); margin: 0px; width: inherit; }

.blog-pager { text-align: center; }

.blog-pager a { color: rgb(33, 150, 243); }

.blog-pager a:visited { color: rgb(33, 150, 243); }

.blog-pager a:hover { color: rgb(33, 150, 243); }

.post-title { font: bold 22px Roboto, sans-serif; float: right; margin: 0px 0px 8px; max-width: calc(100% - 48px); }

.post-title a { font: bold 30px Roboto, sans-serif; }

.post-title, .post-title a, .post-title a:hover, .post-title a:visited { color: rgb(33, 33, 33); }

.post-body { color: rgb(33, 150, 243); font: 15px / 1.6em Roboto, sans-serif; margin: 1.5em 0px 2em; display: block; }

.post-body img { height: inherit; }

.post-body .snippet-thumbnail { float: right; margin: 0px 0px 0px 2em; max-height: 128px; max-width: 128px; }

.post-body .snippet-thumbnail img { max-width: 100%; }

.main .FeaturedPost .widget-content { border: 0px; position: relative; padding-bottom: 0.25em; }

.FeaturedPost img { margin-top: 2em; }

.FeaturedPost .snippet-container { margin: 2em 0px; }

.FeaturedPost .snippet-container p { margin: 0px; }

.FeaturedPost .snippet-thumbnail { float: none; height: auto; margin-bottom: 2em; margin-left: 0px; overflow: hidden; max-height: calc(2em + 600px); max-width: 100%; text-align: center; width: 100%; }

.FeaturedPost .snippet-thumbnail img { max-width: 100%; width: 100%; }

.byline { color: rgba(0, 0, 0, 0.54); display: inline-block; line-height: 24px; margin-top: 8px; vertical-align: top; }

.byline.post-author:first-child { margin-left: 0px; }

.byline.reactions .reactions-label { line-height: 22px; vertical-align: top; }

.byline.post-share-buttons { position: relative; display: inline-block; margin-top: 0px; width: 100%; }

.byline.post-share-buttons .sharing { float: left; }

.flat-button.ripple:hover { background-color: rgba(33, 150, 243, 0.12); }

.flat-button.ripple .splash { background-color: rgba(33, 150, 243, 0.4); }

a.timestamp-link, a:active.timestamp-link, a:visited.timestamp-link { color: inherit; font: inherit; text-decoration: inherit; }

.post-share-buttons { margin-left: 0px; }

.clear-sharing { min-height: 24px; }

.comment-link { color: rgb(33, 150, 243); position: relative; }

.comment-link .num_comments { margin-left: 8px; vertical-align: top; }

