.PopularPosts .post-header .byline { font-size: 0.9em; font-style: italic; margin-top: 6px; }

.PopularPosts ul { list-style: none; padding: 0px; margin: 0px; }

.PopularPosts .post { padding: 20px 0px; }

.PopularPosts .post + .post { border-top: 1px dashed rgb(204, 204, 204); }

.PopularPosts .item-thumbnail { float: right; margin-left: 32px; }

