------MultipartBoundary--nVi4OwSvi7qNvXJBHQTtCxrh8ut0cZWSqdxftM5STR----
Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: cid:css-401ee687-e84b-4d39-998c-f02c825f432b@mhtml.blink

@charset "utf-8";

body { font-family: Arial, sans-serif; margin: 0px; background-color: rgb(18, 18, 18); color: rgb(244, 244, 244); text-align: center; }

header { background-color: rgb(27, 27, 27); padding: 20px; border-bottom: 3px solid rgb(0, 255, 153); }

header h1 { margin: 0px; font-size: 24px; }

.search-container { margin: 20px 0px; display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }

.search-container input { padding: 10px; font-size: 14px; border-radius: 8px; border: 1px solid rgb(0, 255, 153); width: 200px; }

.search-container button { padding: 10px 15px; font-size: 14px; border: none; border-radius: 8px; background: rgb(0, 255, 153); color: rgb(18, 18, 18); cursor: pointer; transition: 0.2s; }

.search-container button:hover { transform: scale(1.05); }

nav { display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 20px 0px; }

.nav-row { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; }

nav a { text-decoration: none; color: rgb(255, 255, 255); display: flex; flex-direction: column; align-items: center; gap: 5px; transition: 0.3s; }

nav a:hover { color: rgb(0, 255, 153); transform: scale(1.1); }

nav a .icon { font-size: 28px; display: block; }

nav a .label { font-size: 12px; }

section { margin: 30px; padding: 20px; border-radius: 10px; background: rgba(255, 255, 255, 0.05); }

h2 { border-bottom: 2px solid rgb(0, 255, 153); display: inline-block; padding-bottom: 5px; }

.games-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin-top: 20px; }

.game-card { background: rgb(42, 42, 42); border-radius: 10px; width: 200px; padding: 10px; transition: 0.3s; }

.game-card:hover { transform: scale(1.05); }

.game-card img { width: 100%; border-radius: 10px; }

.game-card button { width: 100%; margin-top: 10px; padding: 10px; font-size: 14px; background: rgb(0, 255, 153); border: none; border-radius: 8px; cursor: pointer; transition: 0.2s; }

.game-card button:hover { transform: scale(1.05); }

.social-icons { display: flex; justify-content: center; gap: 20px; margin-top: 15px; }

.social-icons a img { width: 50px; height: 50px; transition: 0.2s; }

.social-icons a img:hover { transform: scale(1.2); }

@media (max-width: 600px) {
  nav a { flex: 1 1 70px; max-width: 90px; }
  nav a .icon { font-size: 22px; }
  nav a .label { font-size: 10px; }
  .social-icons a img { width: 40px; height: 40px; }
  .game-card { width: 140px; }
  .game-card button { font-size: 12px; }
  .search-container input { width: 140px; }
  .search-container button { font-size: 12px; padding: 8px 12px; }
}
