.subscribe-button { border-color: rgb(255, 255, 255); color: rgb(255, 255, 255); }

.sticky .subscribe-button { border-color: rgb(33, 150, 243); color: rgb(33, 150, 243); }

.tabs { margin: 0px auto; padding: 0px; }

.tabs li { margin: 0px 8px; vertical-align: top; }

