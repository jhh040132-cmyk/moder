.post-filter-message { background-color: rgba(0, 0, 0, 0.7); color: rgb(255, 255, 255); display: table; margin-bottom: 16px; width: 100%; }

.post-filter-message div { display: table-cell; padding: 15px 28px; }

.post-filter-message div:last-child { padding-right: 0px; text-align: left; }

