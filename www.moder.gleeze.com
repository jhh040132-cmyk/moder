.Vwe4Vb { transform: translate(-50%, -50%) scale(0); transition: opacity 0.2s, visibility 0.2s, transform 0.2s; background-size: cover; right: 0px; opacity: 0; pointer-events: none; position: absolute; top: 0px; visibility: hidden; }

